# ---- Database ----
# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postwing:postwing@localhost:5432/postwing

# ---- Security ----
# Used to sign session tokens / state. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=pw_session
SESSION_TTL_HOURS=720
# In production set COOKIE_SECURE=true (HTTPS) and the right SameSite (lax|none|strict)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Leave COOKIE_DOMAIN empty for host-only cookies (works for localhost across ports)
COOKIE_DOMAIN=

# ---- CORS / frontend ----
FRONTEND_ORIGIN=http://localhost:3000
# Where to send the browser after a successful Google login
FRONTEND_POST_LOGIN_URL=http://localhost:3000/coming-soon

# ---- Google OAuth (fill in later; leave blank to disable the button server-side) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the Google Cloud console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
